FROM alpine:3.19
RUN apk add --no-cache \
    bash vim curl wget iproute2 net-tools iputils \
    tcpdump bind-tools procps htop nginx

# Generate static intranet pages
RUN mkdir -p /var/www/html && \
    echo '<html><head><title>ICS Corp - Home</title></head><body><h1>ICS Corporate Intranet</h1><p>Welcome to the corporate intranet portal. Use the navigation links below to access internal resources, safety documentation, and operational reports.</p><p>For technical support, contact the IT helpdesk at ext. 4200. For OT-related issues, contact the control room at ext. 5100.</p><hr><ul><li><a href="safety.html">Safety Procedures</a></li><li><a href="network.html">Network Status</a></li><li><a href="directory.html">Employee Directory</a></li><li><a href="reports.html">Operational Reports</a></li></ul></body></html>' > /var/www/html/index.html && \
    echo '<html><head><title>Safety Procedures</title></head><body><h1>Safety Procedures Manual</h1><h2>Emergency Shutdown Procedures</h2><p>In the event of an emergency, operators must follow the standard lockout-tagout procedures as outlined in OSHA 1910.147. All PLCs in the affected zone must be placed in safe mode before any physical intervention.</p><h2>Chemical Handling</h2><p>All chemical storage areas must maintain proper ventilation. MSDS sheets are available at each workstation and in the central repository. Spill kits are located at stations A through F along the production floor.</p><h2>Access Control</h2><p>Level 0 and Level 1 areas require badge access and supervisor authorization. Visitors must be accompanied at all times in the production area. All access events are logged in the security information system.</p></body></html>' > /var/www/html/safety.html && \
    echo '<html><head><title>Network Status</title></head><body><h1>Network Infrastructure Status</h1><h2>IT Network</h2><p>Core switches: Online. Uptime: 99.97%. Last maintenance window: scheduled for next quarter. Active workstations: monitoring in progress.</p><h2>OT Network</h2><p>SCADA server: Operational. PLC communication: Normal. Modbus/TCP polling interval: 1 second. Historian database: Recording. Last backup: automated daily at 02:00.</p><h2>DMZ</h2><p>Firewall status: Active. Rules last updated this cycle. All cross-zone traffic is filtered and logged. No anomalies detected in the current reporting period.</p></body></html>' > /var/www/html/network.html && \
    echo '<html><head><title>Employee Directory</title></head><body><h1>Employee Directory</h1><table border="1" cellpadding="8"><tr><th>Name</th><th>Department</th><th>Extension</th><th>Role</th></tr><tr><td>A. Smith</td><td>IT</td><td>4201</td><td>Network Administrator</td></tr><tr><td>B. Jones</td><td>OT</td><td>5101</td><td>Control Systems Engineer</td></tr><tr><td>C. Williams</td><td>IT</td><td>4202</td><td>Security Analyst</td></tr><tr><td>D. Brown</td><td>OT</td><td>5102</td><td>SCADA Operator</td></tr><tr><td>E. Davis</td><td>Management</td><td>3001</td><td>Plant Manager</td></tr><tr><td>F. Wilson</td><td>IT</td><td>4203</td><td>Systems Administrator</td></tr><tr><td>G. Taylor</td><td>OT</td><td>5103</td><td>Instrumentation Technician</td></tr><tr><td>H. Anderson</td><td>Safety</td><td>6001</td><td>HSE Coordinator</td></tr></table></body></html>' > /var/www/html/directory.html && \
    echo '<html><head><title>Reports</title></head><body><h1>Operational Reports</h1><h2>Production Summary</h2><p>Current shift output is within normal parameters. All production lines are operational. Batch processing unit 3 completed cycle at expected intervals. Quality control samples passed inspection.</p><h2>Maintenance Log</h2><p>Preventive maintenance completed on compressor unit C-201. Valve replacement scheduled for reactor R-105 during next planned shutdown. PLC firmware updates pending approval for Zone 4 controllers.</p><h2>Energy Consumption</h2><p>Total facility consumption is tracking at nominal levels. Peak demand management system is active. Solar array contributing expected output for current weather conditions.</p></body></html>' > /var/www/html/reports.html && \
    echo '<html><head><title>Policies</title></head><body><h1>Corporate Policies</h1><h2>Acceptable Use Policy</h2><p>All company IT resources are to be used for business purposes only. Personal use of company equipment must be approved by department supervisors. All network activity is subject to monitoring and logging for security and compliance purposes.</p><h2>Remote Access Policy</h2><p>Remote access to corporate resources requires VPN authentication with multi-factor authentication enabled. Remote access to OT networks is strictly prohibited without explicit approval from the OT security team and must be conducted through the designated jump server.</p></body></html>' > /var/www/html/policies.html && \
    echo '<html><head><title>Training</title></head><body><h1>Training Resources</h1><p>All employees must complete annual cybersecurity awareness training. OT personnel must additionally complete ICS-specific security training covering topics including network segmentation, Modbus protocol security, and incident response procedures.</p><p>Training modules are available through the learning management system. Contact HR for enrollment information and scheduling.</p></body></html>' > /var/www/html/training.html

# Nginx config — serve from /var/www/html on port 80
RUN printf 'server {\n  listen 80 default_server;\n  root /var/www/html;\n  index index.html;\n  location / { try_files $uri $uri/ =404; }\n}\n' > /etc/nginx/http.d/default.conf

CMD ["tail", "-f", "/dev/null"]
